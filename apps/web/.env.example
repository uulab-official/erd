# Copy to .env.local and fill in your Appwrite project's values.
# Left unset, the app falls back to an in-memory ModelStore and disables Auth —
# useful for local UI work without a real Appwrite backend.
VITE_APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_MODELS_TABLE_ID=
